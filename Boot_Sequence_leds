#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ST7735.h>

#define TFT_CS   5
#define TFT_DC   2
#define TFT_RST  4

Adafruit_ST7735 tft(TFT_CS, TFT_DC, TFT_RST);

int cx = 80;
int cy = 127;
int maxR = 78;

float deg2rad(int d) {
  return d * 0.0174532925;
}

void drawRadarHUD() {
  tft.fillScreen(ST77XX_BLACK);

  int r1 = maxR;
  int r2 = maxR * 2 / 3;
  int r3 = maxR / 3;

  // --- half-circle arcs ---
  for (int a = 0; a <= 180; a++) {
    float rad = deg2rad(a);

    tft.drawPixel(cx + cos(rad) * r1, cy - sin(rad) * r1, ST77XX_RED);
    tft.drawPixel(cx + cos(rad) * r2, cy - sin(rad) * r2, ST77XX_RED);
    tft.drawPixel(cx + cos(rad) * r3, cy - sin(rad) * r3, ST77XX_RED);
  }

  // --- baseline ---
  tft.drawFastHLine(cx - maxR, cy, maxR * 2, ST77XX_RED);

  // --- bearing lines from center ---
  int bearings[] = {30, 60, 90, 120, 150};

  for (int i = 0; i < 5; i++) {
    float rad = deg2rad(bearings[i]);
    tft.drawLine(
      cx, cy,
      cx + cos(rad) * maxR,
      cy - sin(rad) * maxR,
      ST77XX_RED
    );
  }
}

void setup() {
  tft.initR(INITR_BLACKTAB);
  tft.setRotation(1);
  drawRadarHUD();
}

void loop() {
  // static radar GUI
}

